#!/usr/bin/env bash
# Launcher for DocToMarkdown.app on macOS.
# Boots the Flask backend and hosts the UI in a native WKWebView window.
set -e

RUNTIME_DIR="$HOME/Library/Application Support/DocToMarkdown"

export PATH="$RUNTIME_DIR/.venv/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

# Bootstrap runtime if missing (first launch after user deleted app support dir)
if [[ ! -x "$RUNTIME_DIR/.venv/bin/python" ]] || [[ ! -f "$RUNTIME_DIR/src/desktop_app.py" ]]; then
  osascript -e 'display notification "Configurando pela primeira vez… (pode levar alguns segundos)" with title "DocToMarkdown"' 2>/dev/null || true
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL https://raw.githubusercontent.com/diegombraga/DocToMarkdown/main/install.sh | bash --ci
  fi
fi

# Native app: Flask + pywebview window in one process. Closing the window
# terminates the process — no orphan servers, no browser tab confusion.
exec "$RUNTIME_DIR/.venv/bin/python" "$RUNTIME_DIR/src/desktop_app.py"
